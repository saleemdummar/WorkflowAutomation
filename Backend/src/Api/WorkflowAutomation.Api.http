@WorkflowAutomation.Api_HostAddress = http://localhost:5121
@token = REPLACE_WITH_JWT
@roleId = REPLACE_WITH_ROLE_ID

### Basic API check
GET {{WorkflowAutomation.Api_HostAddress}}/weatherforecast/
Accept: application/json

### List all system permissions
GET {{WorkflowAutomation.Api_HostAddress}}/api/Role/permissions/all
Authorization: Bearer {{token}}
Accept: application/json

### Get permissions for a role
GET {{WorkflowAutomation.Api_HostAddress}}/api/Role/{{roleId}}/permissions
Authorization: Bearer {{token}}
Accept: application/json

### Grant permission to a role
POST {{WorkflowAutomation.Api_HostAddress}}/api/Role/{{roleId}}/permissions
Authorization: Bearer {{token}}
Content-Type: application/json

{
	"permission": "CreateForm"
}

### Revoke permission from a role
DELETE {{WorkflowAutomation.Api_HostAddress}}/api/Role/{{roleId}}/permissions/CreateForm
Authorization: Bearer {{token}}

### Attempt to create a form (requires CanCreateForms policy)
POST {{WorkflowAutomation.Api_HostAddress}}/api/Forms
Authorization: Bearer {{token}}
Content-Type: application/json

{
	"name": "Test Permission Form",
	"description": "Form created via permission validation",
	"categoryId": null,
	"fields": []
}

###
